<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvHubTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/hub_title"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#202124"
        app:layout_constraintBottom_toTopOf="@+id/tvHubSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvHubSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/o_que_voc_deseja_fazer_hoje"
        android:textSize="16sp"
        android:textColor="#5F6368"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toTopOf="@+id/btnCalculadora"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvHubTitle" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCalculadora"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/btn_calculadora"
        android:textStyle="bold"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_menu_view"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:layout_constraintBottom_toTopOf="@+id/btnContador"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvHubSubtitle" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContador"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:text="@string/btn_contador"
        android:textStyle="bold"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_menu_sort_by_size"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:layout_constraintBottom_toTopOf="@+id/btnListaCompras"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnCalculadora" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnListaCompras"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:text="@string/btn_lista_compras"
        android:textStyle="bold"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_menu_agenda"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnContador" />

</androidx.constraintlayout.widget.ConstraintLayout>